{
  "extends": "../../packages/typescript-config/base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "skipLibCheck": true,
    "allowJs": true,
    "esModuleInterop": true
  },
  "include": [
    "index.ts",
    "prisma.config.ts",
    "src",
    "generated"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "prisma/seed.ts",
    "generated/**"
  ]
}